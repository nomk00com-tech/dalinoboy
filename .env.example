# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather. DO NOT commit a real token — set it as a Railway variable.
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram IDs of administrators
# Tip: send /start to the bot, then check bot.log or Telegram's @userinfobot
ADMIN_IDS=123456789,987654321

# Optional: path to the SQLite file. On Railway point this at a mounted volume
# so data survives redeploys, e.g. DB_PATH=/data/puesc_bot.db
# DB_PATH=/data/puesc_bot.db

# ── PUESC / SENT ──────────────────────────────────────────────────────────────
# No credentials needed — the RMPD-406 form is public ("dostępna bez logowania").

# ── Checker / monitoring settings ─────────────────────────────────────────────
# How often (minutes) the bot automatically checks all active trips.
CHECK_INTERVAL_MINUTES=5

# Locator silent for more than this many minutes = "not transmitting now"
# (device normally reports every few minutes). Note: a position whose timestamp
# keeps advancing between checks counts as transmitting even past this limit, so
# normal GEO-portal lag won't read as "no signal".
SIGNAL_FRESH_MINUTES=20

# First notice (signal lost, stop & wait) after this many minutes lost WHILE MOVING.
WARN_MINUTES=30
# Fine notice if still no signal after this many minutes (30 min after the warning).
FINE_MINUTES=60

# Minimum displacement (metres) between checks counted as "the vehicle moved".
MOVE_THRESHOLD_M=500

# How often (minutes) to poll PUESC news for the SENT/monitoring category.
NEWS_INTERVAL_MINUTES=30

# PUESC news category URL ("Przewóz towarów objęty monitorowaniem"). Change only
# if PUESC restructures the portal.
NEWS_CATEGORY_URL=https://puesc.gov.pl/aktualnosci/-/categories/603451585?p_r_p_resetCur=true&p_r_p_categoryId=603451585

# ── Test data for standalone checker.py ───────────────────────────────────────
# Used when running:  python checker.py
# Locator format enforced by PUESC: Z|U|M + 2 digits - 2 letters 2 digits 2 letters - 1 digit
# (e.g. Z21-AF67XZ-8). One RMPD can have a main + a backup locator (checked separately).
TEST_RMPD=RMPD20260607000433
TEST_PLATE=BC8849PO
TEST_TRACKER=Z21-AF67XZ-8
